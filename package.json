{
  "name": "pstbn",
  "version": "0.0.0",
  "license": "MIT",
  "repository": "github:o-az/pstbn",
  "bin": {
    "pstbn": "./src/bin.ts"
  },
  "type": "module",
  "imports": {
    "#*": "./src/*",
    "#openapi.json": "./openapi.json",
    "#package.json": "./package.json",
    "#wrangler.json": "./wrangler.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "oxfmt --config='oxfmt.config.ts' --write",
    "lint": "oxlint --config='oxlint.config.ts' --type-aware --type-check --fix-dangerously",
    "check": "bun format && bun lint",
    "deploy": "NODE_ENV='production' wrangler deploy",
    "check:types": "bun tsgo --project tsconfig.json --noEmit",
    "types": "wrangler types --env-interface CloudflareBindings",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@scalar/hono-api-reference": "^0.10.4",
    "@std/ulid": "npm:@jsr/std__ulid",
    "hono": "^4.12.9",
    "incur": "^0.3.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.0",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@j178/prek": "^0.3.8",
    "@scalar/api-reference": "^1.49.3",
    "@scalar/types": "^0.7.4",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260323.1",
    "@vitejs/devtools": "^0.1.8",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.2",
    "simple-git-hooks": "^2.13.1",
    "typed-query-selector": "^2.12.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plugin-inspect": "^11.3.3",
    "wrangler": "^4.76.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bun prek run --all-files --config='.github/.pre-commit.yml' && bun check"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "@j178/prek"
  ]
}
