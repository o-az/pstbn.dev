{
  "name": "pstbn.dev",
  "version": "0.0.1",
  "description": "Agent-first, simple, robust pastebin",
  "homepage": "https://pstbn.dev",
  "license": "MIT",
  "author": "omar <code@omar.mov>",
  "repository": "github:o-az/pstbn.dev",
  "bin": {
    "pstbn": "./dist/bin.js"
  },
  "files": [
    "dist/bin.js",
    "openapi.json",
    ".github/README.md"
  ],
  "type": "module",
  "imports": {
    "#*": "./src/*",
    "#openapi.json": "./openapi.json",
    "#package.json": "./package.json",
    "#wrangler.json": "./wrangler.json"
  },
  "scripts": {
    "dev": "vite dev --mode='development' --config='vite.config.ts'",
    "build": "bun build ./src/bin.ts --target='node' --outdir='./dist' --outfile='./dist/bin.js' --format='esm' --target='node'",
    "test": "echo 'noop'",
    "preview": "vite preview",
    "format": "oxfmt --config='oxfmt.config.ts' --write",
    "lint": "oxlint --config='oxlint.config.ts' --type-aware --type-check --fix-dangerously",
    "check": "bun format && bun lint",
    "deploy": "NODE_ENV='production' wrangler deploy",
    "check:types": "bun tsgo --project tsconfig.json --noEmit",
    "types": "wrangler types --env-interface CloudflareBindings",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@std/ulid": "npm:@jsr/std__ulid",
    "hono": "^4.12.19",
    "incur": "^0.4.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.1",
    "@cloudflare/workers-types": "^4.20260519.1",
    "@j178/prek": "^0.4.0",
    "@scalar/api-reference": "^1.57.2",
    "@scalar/types": "^0.11.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.0",
    "@typescript/native-preview": "^7.0.0-dev.20260518.1",
    "@vitejs/devtools": "^0.1.24",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.23.0",
    "simple-git-hooks": "^2.13.1",
    "typed-query-selector": "^2.12.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plugin-inspect": "^12.0.0-beta.2",
    "wrangler": "^4.92.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": ">=4"
  },
  "peerDependenciesMeta": {
    "@cloudflare/workers-types": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "bun prek run --all-files --config='.github/.pre-commit.yml' && bun check"
  },
  "packageManager": "bun@1.3.14",
  "readme": ".github/README.md",
  "trustedDependencies": [
    "@j178/prek",
    "core-js",
    "esbuild",
    "simple-git-hooks",
    "workerd"
  ]
}
