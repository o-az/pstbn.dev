{
  "name": "pstbn",
  "version": "0.0.1",
  "description": "Agent-first, simple, robust pastebin",
  "homepage": "https://pstbn.dev",
  "license": "MIT",
  "author": "omar <code@omar.mov>",
  "repository": "github:o-az/pstbn.dev",
  "bin": {
    "pstbn": "./dist/bin.mjs"
  },
  "files": [
    "src/bin.ts",
    "src/cli.ts",
    "src/storage.ts"
  ],
  "type": "module",
  "imports": {
    "#*": "./src/*",
    "#openapi.json": "./openapi.json",
    "#package.json": "./package.json",
    "#wrangler.json": "./wrangler.json"
  },
  "scripts": {
    "dev": "vite dev --mode='development' --config='vite.config.ts'",
    "build": "vite build --mode='production' --config='vite.config.ts'",
    "buiuld:npm": "bun build src/bin.ts --target=node src/bin.ts --outdir=dist --format=esm --target=node",
    "test": "echo 'noop'",
    "preview": "vite preview",
    "format": "oxfmt --config='oxfmt.config.ts' --write",
    "lint": "oxlint --config='oxlint.config.ts' --type-aware --type-check --fix-dangerously",
    "check": "bun format && bun lint",
    "deploy": "NODE_ENV='production' wrangler deploy",
    "check:types": "bun tsgo --project tsconfig.json --noEmit",
    "types": "wrangler types --env-interface CloudflareBindings",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@std/ulid": "npm:@jsr/std__ulid",
    "hono": "^4.12.9",
    "incur": "^0.3.13",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@j178/prek": "^0.3.8",
    "@scalar/api-reference": "^1.49.5",
    "@scalar/types": "^0.7.5",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260328.1",
    "@vitejs/devtools": "^0.1.11",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "simple-git-hooks": "^2.13.1",
    "typed-query-selector": "^2.12.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plugin-inspect": "^12.0.0-beta.1",
    "wrangler": "^4.78.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": ">=4"
  },
  "peerDependenciesMeta": {
    "@cloudflare/workers-types": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "bun prek run --all-files --config='.github/.pre-commit.yml' && bun check"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "@j178/prek",
    "core-js",
    "esbuild",
    "simple-git-hooks",
    "workerd"
  ]
}
