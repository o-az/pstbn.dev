{
  "file_types": {
    "env": [".env", ".env.*"],
    "tailwindcss": ["*.css"]
  },
  "hidden_files": ["**/.wrangler", "**/.tanstack", "**/.claude", "**/.cursor", "**/.agents"],
  "file_scan_exclusions": [
    "**/.wrangler",
    "**/.tanstack",
    "**/.vscode",
    ".git",
    "**/.claude",
    "**/.cursor",
    "**/.agents"
  ],
  "lsp": {
    "tombi": {
      "fetch": {
        "pre_release": true
      },
      "binary": {
        "arguments": ["lsp", "-v"],
        "env": {
          "NO_COLOR": "true"
        },
        "ignore_system_version": false
      }
    },
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": "oxlint.config.ts",
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": "oxfmt.config.ts",
          "run": "onSave"
        }
      }
    }
  },
  "languages": {
    "TOML": {
      "format_on_save": "on",
      "language_servers": ["tombi"],
      "show_edit_predictions": false,
      "formatter": {
        "language_server": {
          "name": "tombi"
        }
      }
    },
    "CSS": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "HTML": {
      "format_on_save": "on",
      "language_servers": ["oxc"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Markdown": {
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint", "markdown-oxide"],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSON": {
      "format_on_save": "on",
      "language_servers": ["json-language-server", "oxfmt", "oxlint"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSONC": {
      "format_on_save": "on",
      "language_servers": ["json-language-server", "oxfmt", "oxlint"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSDoc": {
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint"],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "TSX": {
      "format_on_save": "on",
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JavaScript": {
      "format_on_save": "on",
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "TypeScript": {
      "format_on_save": "on",
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "YAML": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    }
  }
}
