{
  "file_types": {
    "env": [".env", ".env.*"],
    "tailwindcss": ["*.css"]
  },
  "hidden_files": ["**/.wrangler", "**/.tanstack", "**/.claude", "**/.cursor", "**/.agents"],
  "file_scan_exclusions": [
    "**/.wrangler",
    "**/.tanstack",
    "**/.vscode",
    ".git",
    "**/.claude",
    "**/.cursor",
    "**/.agents"
  ],
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx", "twMerge", "class", "tw\\.[a-z-]+", "cn", "clsx"],
        "experimental": {
          "classRegex": ["(?:cls|class|className|classList)\\s\\:\\=\\s\"([^\"]*)"]
        }
      }
    },
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": ".oxlintrc.json",
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": ".oxfmtrc.json",
          "run": "onSave"
        }
      }
    }
  },
  "languages": {
    "CSS": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "HTML": {
      "format_on_save": "on",
      "language_servers": ["oxc"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "MDX": {
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint"],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Markdown": {
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint", "markdown-oxide"],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSON": {
      "format_on_save": "on",
      "language_servers": ["json-language-server", "oxfmt", "oxlint"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSONC": {
      "format_on_save": "on",
      "language_servers": ["json-language-server", "oxfmt", "oxlint"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSDoc": {
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint"],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "TSX": {
      "format_on_save": "on",
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JavaScript": {
      "format_on_save": "on",
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
