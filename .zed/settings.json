{
  "file_types": {
    "ini": [
      "**/.npmrc"
    ],
    "env": [
      ".env",
      ".env.*"
    ],
    "JSONC": [
      "**/wrangler.json",
      "**/.zed/**/*.json"
    ]
  },
  "hidden_files": [
    "**/.wrangler"
  ],
  "file_scan_exclusions": [
    ".git",
    "**/.vscode",
    "**/.wrangler"
  ],
  "use_autoclose": true,
  "enable_language_server": true,
  "formatter": "language_server",
  "prettier": {
    "allowed": false
  },
  "use_auto_surround": true,
  "language_servers": [
    "!vtsls",
    "!biome",
    "!eslint",
    "!typescript-language-server",

    "typescript-ls",
    "tombi",
    "oxfmt",
    "oxlint",
    "markdown-oxide",
    "html-language-server",
    "json-language-server",
    "vscode-css-languageservice",
    "vscode-html-languageservice"
  ],
  "lsp": {
    "tombi": {
      "fetch": {
        "pre_release": true
      },
      "binary": {
        "arguments": [
          "lsp",
          "-v"
        ],
        "env": {
          "NO_COLOR": "true"
        },
        "ignore_system_version": false
      }
    },
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": "oxlint.config.ts",
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": "oxfmt.config.ts",
          "run": "onSave"
        }
      }
    }
  },
  "languages": {
    "TOML": {
      "format_on_save": "on",
      "language_servers": [
        "tombi"
      ],
      "show_edit_predictions": false,
      "formatter": {
        "language_server": {
          "name": "tombi"
        }
      }
    },
    "CSS": {
      "format_on_save": "on",
      "language_servers": [
        "vscode-css-languageservice",
        "oxfmt",
        "oxlint",
        "!eslint",
        "!biome"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "HTML": {
      "format_on_save": "on",
      "language_servers": [
        "vscode-html-languageservice",
        "oxfmt",
        "oxlint",
        "!eslint",
        "!biome"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Markdown": {
      "language_servers": [
        "typescript-ls",
        "oxfmt",
        "oxlint",
        "markdown-oxide",
        "!eslint",
        "!biome",
        "!typescript-language-server"
      ],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSON": {
      "format_on_save": "on",
      "language_servers": [
        "json-language-server",
        "oxfmt",
        "oxlint",
        "!eslint",
        "!biome"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSONC": {
      "format_on_save": "on",
      "language_servers": [
        "json-language-server",
        "oxfmt",
        "oxlint",
        "!eslint",
        "!biome"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSDoc": {
      "language_servers": [
        "typescript-ls",
        "oxfmt",
        "oxlint",
        "!eslint",
        "!biome",
        "!typescript-language-server"
      ],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "TSX": {
      "format_on_save": "on",
      "language_servers": [
        "typescript-ls",
        "oxfmt",
        "oxlint",
        "!eslint",
        "!biome",
        "!typescript-language-server"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JavaScript": {
      "format_on_save": "on",
      "language_servers": [
        "typescript-ls",
        "oxfmt",
        "oxlint",
        "!eslint",
        "!biome",
        "!typescript-language-server"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "TypeScript": {
      "format_on_save": "on",
      "language_servers": [
        "typescript-ls",
        "oxfmt",
        "oxlint",
        "!eslint",
        "!biome",
        "!typescript-language-server"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "YAML": {
      "format_on_save": "on",
      "language_servers": [
        "oxfmt",
        "oxlint",
        "yaml-language-server"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    }
  }
}
